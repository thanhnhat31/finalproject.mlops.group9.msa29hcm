{
  "__comment": "TODO: Create ML Metrics Dashboard - See instructions below",
  "__instructions": [
    "This dashboard should display ML-specific metrics for model monitoring.",
    "",
    "TODO 1: Create a 'Model Status' panel",
    "  - Type: Stat",
    "  - Query: ml_model_loaded",
    "  - Value mappings: 0 = Not Loaded (red), 1 = Loaded (green)",
    "",
    "TODO 2: Create a 'Prediction Rate' panel",
    "  - Type: Time series graph",
    "  - Query: rate(ml_predictions_total[5m])",
    "",
    "TODO 3: Create a 'Prediction Latency (P95)' panel",
    "  - Type: Time series graph",
    "  - Query: histogram_quantile(0.95, rate(ml_prediction_duration_seconds_bucket[5m]))",
    "  - Unit: seconds",
    "",
    "TODO 4: Create a 'Prediction Value Distribution' panel",
    "  - Type: Histogram or Heatmap",
    "  - Query: rate(ml_prediction_value_bucket[5m])",
    "",
    "TODO 5: Create an 'Average Prediction' panel",
    "  - Type: Gauge or Stat",
    "  - Query: histogram_quantile(0.5, rate(ml_prediction_value_bucket[5m]))",
    "  - Min: 1, Max: 5",
    "",
    "TODO 6: Create a 'Prediction Errors' panel",
    "  - Type: Time series graph",
    "  - Query: rate(ml_prediction_errors_total[5m])",
    "  - Legend: {{error_type}}",
    "",
    "TODO 7: Create a 'Model Info' panel",
    "  - Type: Table",
    "  - Query: ml_model_info",
    "",
    "HOW TO CREATE:",
    "1. Open Grafana at http://localhost:3000",
    "2. Create new dashboard",
    "3. Add panels with the queries above",
    "4. Export dashboard JSON and save here"
  ],
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Model Status",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [{"expr": "ml_model_loaded", "refId": "A"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "Not Loaded"}, "1": {"text": "Loaded"}}}], "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}}
    },
    {
      "id": 2,
      "title": "Average Prediction",
      "type": "gauge",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [{"expr": "(sum(rate(ml_prediction_probability_sum[5m])) / clamp_min(sum(rate(ml_prediction_probability_count[5m])), 0.001)) or vector(0)", "refId": "A"}],
      "fieldConfig": {"defaults": {"min": 0, "max": 1, "unit": "percentunit"}, "overrides": []}
    },
    {
      "id": 3,
      "title": "Prediction Rate",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [{"expr": "sum(rate(ml_predictions_total[5m]))", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []}
    },
    {
      "id": 4,
      "title": "Prediction Errors",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [{"expr": "sum(rate(ml_prediction_errors_total[5m])) or vector(0)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []}
    },
    {
      "id": 5,
      "title": "Prediction Rate Over Time",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [{"expr": "sum by (model_version) (rate(ml_predictions_total[5m]))", "legendFormat": "v{{model_version}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []}
    },
    {
      "id": 6,
      "title": "Prediction Latency Quantiles",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by (le) (rate(ml_prediction_duration_seconds_bucket[5m])))", "legendFormat": "P50", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(ml_prediction_duration_seconds_bucket[5m])))", "legendFormat": "P95", "refId": "B"},
        {"expr": "histogram_quantile(0.99, sum by (le) (rate(ml_prediction_duration_seconds_bucket[5m])))", "legendFormat": "P99", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "id": 7,
      "title": "Prediction Value Distribution",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [{"expr": "sum by (le) (rate(ml_prediction_probability_bucket[5m]))", "legendFormat": "<= {{le}}", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []}
    },
    {
      "id": 8,
      "title": "Prediction Errors (5m)",
      "type": "stat",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [{"expr": "sum(rate(ml_prediction_errors_total[5m])) or vector(0)", "refId": "A"}],
      "fieldConfig": {"defaults": {"unit": "reqps", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 0.01}, {"color": "red", "value": 0.05}]}}, "overrides": []}
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["ml", "model", "ddm501"],
  "templating": {"list": []},
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "ML Metrics Dashboard",
  "uid": "ml-metrics",
  "version": 3,
  "weekStart": ""
}
